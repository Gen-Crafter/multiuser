# ===== Application =====
APP_NAME=LinkedInCampaignPlatform
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_HOSTS=*

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=linkedin_platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# ===== JWT =====
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Ollama LLM =====
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ===== Encryption =====
ENCRYPTION_KEY=change-me-fernet-key-base64

# ===== Proxy =====
PROXY_LIST_PATH=/app/proxies.txt
PROXY_ROTATION_ENABLED=true

# ===== Browser Automation =====
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=50
SESSION_STORAGE_PATH=/app/sessions

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ===== Nginx =====
NGINX_PORT=80
